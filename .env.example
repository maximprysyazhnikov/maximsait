PORT=3000
APP_URL=http://localhost:3000

# Server-side OpenRouter configuration.
# Both values are required. The app reads them only from the environment.
# You can provide one key or multiple keys separated by commas, semicolons, or new lines.
# The server will randomly pick a key per request and retry with another key on auth/credit/rate-limit failures.
# Do not expose the real key in frontend code or commit it to git.
OPENROUTER_KEYS=your_openrouter_key_here,another_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
